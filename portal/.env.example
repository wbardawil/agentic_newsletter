NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

ANTHROPIC_API_KEY=

# Full origin where the portal is reachable (no trailing slash).
# In production this is your apex domain. In dev it's http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Base path the portal is mounted under. Leave blank when serving the
# whole app from the root (subdomain or local dev). Set to "/letter" when
# you proxy wadibardawil.com/letter/* to this deployment.
NEXT_PUBLIC_BASE_PATH=

ADMIN_EMAILS=wadi@example.com
