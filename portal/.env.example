# Supabase — database + storage
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=   # bypasses RLS; server-side only, never expose to browser

ANTHROPIC_API_KEY=

# Full origin where the portal is reachable (no trailing slash).
# In production this is your apex domain. In dev it's http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Base path the portal is mounted under. Leave blank when serving the
# whole app from the root. Set to "/letter" when proxying from a subpath.
NEXT_PUBLIC_BASE_PATH=

ADMIN_EMAILS=wadi@example.com

# ── GitHub Contents API ───────────────────────────────────────────────────────
# Required for: admin draft editor, review state read/write, rejection.json write
# Use a fine-grained PAT scoped to this repo only: Contents: read/write, Issues: write
# In Vercel, set as Sensitive and ONLY in Production env.
GITHUB_TOKEN=
GITHUB_REPO=wbardawil/agentic_newsletter
GITHUB_DRAFT_BRANCH_PREFIX=drafts/   # branch name prefix for draft PRs

# ── Editorial review gate ─────────────────────────────────────────────────────
# Shared HMAC-SHA256 secret between the pipeline digest sender and this portal.
# The same value must be set in the pipeline's APPROVAL_SIGNING_SECRET.
# Generate: openssl rand -base64 48
# In Vercel: set in Production env only (never Preview).
APPROVAL_SIGNING_SECRET=

# Quality gate — minimum Validator score to allow publishing
QA_MIN_SCORE=70

# Emergency bypass: set to "true" to publish without checking image/content approvals.
# Only for migration or recovery — revert immediately after use.
SKIP_REVIEW_GATE=false

# ── Newsletter metadata ───────────────────────────────────────────────────────
NEWSLETTER_AUTHOR=Wadi Bardawil
