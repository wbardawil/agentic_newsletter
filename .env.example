# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini (Designer agent — image generation; optional)
GEMINI_API_KEY=

# Beehiiv
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Feedly
FEEDLY_API_KEY=

# Social (optional)
LINKEDIN_ACCESS_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Airtable (optional)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Supabase — portal mirror + image asset storage (optional)
# On publish: editions + sources are upserted into `editions`/`edition_sources`.
# On image generation: hero image is uploaded to `edition-assets` bucket as
#   `edition-assets/<editionId>/hero-v<attempt>.png` and the public URL is
#   stored in review.json → used as hero_image_url in the newsroom.
# Service-role key bypasses RLS; server-side only, never commit.
# If unset, mirror and storage upload are skipped (non-fatal).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend — draft digest email (optional; phase 1 of the email approval gate)
RESEND_API_KEY=
RESEND_FROM=
RESEND_TO=

# Approval Worker — one-click magic-link publish (optional; phase 2)
# Both must be set together. The same APPROVAL_SIGNING_SECRET goes into the
# Cloudflare Worker. See workers/approval-receiver/README.md.
APPROVAL_BASE_URL=
APPROVAL_SIGNING_SECRET=

# Portal editor — when set, the digest email includes an "Edit in portal"
# deep-link to /admin/drafts/<edition>/edit. Full origin + basePath:
# e.g. "https://wadibardawil.com/letter" in production, "http://localhost:3000"
# in dev. Auth is enforced by the portal (Supabase + ADMIN_EMAILS).
PORTAL_BASE_URL=

# App
LOG_LEVEL=info
DRY_RUN=false
MAX_COST_PER_RUN_USD=5.00
LLM_TIMEOUT_MS=120000
NEWSLETTER_AUTHOR=Wadi Bardawil
RSS_PARSER_TIMEOUT_MS=12000

# Regeneration limits — stop infinite loops and create GitHub issues when exceeded
# Image: max hero image regeneration attempts before requiring human intervention (default 5)
MAX_IMAGE_REGEN_ATTEMPTS=5
# Content: max full draft reruns after rejection before requiring human intervention (default 3)
MAX_CONTENT_REGEN_ATTEMPTS=3

# GitHub — used to create human-intervention issues when regen limits are exceeded
# GITHUB_TOKEN is available automatically in GitHub Actions; set locally for testing
# GITHUB_REPOSITORY is set automatically in Actions (format: owner/repo)
# GITHUB_TOKEN=
# GITHUB_REPOSITORY=owner/repo
