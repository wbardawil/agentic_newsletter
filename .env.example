# Anthropic
ANTHROPIC_API_KEY=

# Google Gemini (Designer agent — image generation; optional)
GEMINI_API_KEY=

# Beehiiv
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Feedly
FEEDLY_API_KEY=

# Social (optional)
LINKEDIN_ACCESS_TOKEN=
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# Airtable (optional)
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=

# Resend — draft digest email (optional; phase 1 of the email approval gate)
RESEND_API_KEY=
RESEND_FROM=
RESEND_TO=

# Approval Worker — one-click magic-link publish (optional; phase 2)
# Both must be set together. The same APPROVAL_SIGNING_SECRET goes into the
# Cloudflare Worker. See workers/approval-receiver/README.md.
APPROVAL_BASE_URL=
APPROVAL_SIGNING_SECRET=

# App
LOG_LEVEL=info
DRY_RUN=false
MAX_COST_PER_RUN_USD=5.00
LLM_TIMEOUT_MS=120000
NEWSLETTER_AUTHOR=Wadi Bardawil
RSS_PARSER_TIMEOUT_MS=12000
